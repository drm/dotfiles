# Skip chromium's keyring/Secret Service probe at startup.
#
# Without a Secret Service provider running (no gnome-keyring, no kwalletd,
# no keepassxc with secret-service mode), chromium's async OSCrypt path
# blocks ~25s waiting for a backend before falling back to plaintext.
# That wait gates the first navigation, so every cold start is ~25s slow.
#
# Setting --password-store=basic skips the probe entirely. Trade-off:
# cookies/passwords are obfuscated, not encrypted, on disk. Acceptable on
# a single-user laptop with full-disk encryption.
export CHROMIUM_FLAGS="$CHROMIUM_FLAGS --password-store=basic"
